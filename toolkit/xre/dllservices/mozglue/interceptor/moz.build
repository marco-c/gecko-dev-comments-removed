





EXPORTS.mozilla.interceptor += [
    "Arm64.h",
    "MMPolicies.h",
    "PatcherBase.h",
    "PatcherDetour.h",
    "PatcherNopSpace.h",
    "RangeMap.h",
    "TargetFunction.h",
    "Trampoline.h",
    "VMSharingPolicies.h",
]

if CONFIG["TARGET_CPU"] == "aarch64":
    Library("interceptor")

    FINAL_LIBRARY = "mozglue"

    UNIFIED_SOURCES += [
        "Arm64.cpp",
    ]
