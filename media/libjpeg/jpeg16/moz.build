with Files("**"):
    BUG_COMPONENT = ("Core", "Graphics: ImageLib")

DEFINES['BITS_IN_JSAMPLE'] = 16

LOCAL_INCLUDES += [
    '/media/libjpeg',
    '/media/libjpeg/src',
]

# From JPEG16_SOURCES in the upstream CMakeLists.txt
SOURCES += [
    '../src/jcapistd.c',
    '../src/jccolor.c',
    '../src/jcdiffct.c',
    '../src/jclossls.c',
    '../src/jcmainct.c',
    '../src/jcprepct.c',
    '../src/jcsample.c',
    '../src/jdapistd.c',
    '../src/jdcolor.c',
    '../src/jddiffct.c',
    '../src/jdlossls.c',
    '../src/jdmainct.c',
    '../src/jdpostct.c',
    '../src/jdsample.c',
    '../src/jutils.c',
]

# We allow warnings for third-party code that can be updated from upstream.
AllowCompilerWarnings()

FINAL_LIBRARY = 'xul'

