-#
-# This template generates:
-# 1. A static library containing the test sources.
-# 2. An executable to run the test locally.
-# 3. A verification step to ensure the test is included in at least one
-#    `rtc_test_suite` (when not building with Chromium).
-#
-# Arguments:
-#   sources: List of source files.
-#   deps: List of dependencies.
-#   data_deps: List of data dependencies.
-#   ... (other standard rtc_library arguments)
-template("rtc_cc_test") {
-  _lib_target_name = "${target_name}"
-
-  rtc_library(_lib_target_name) {
-    forward_variables_from(invoker,
-                           "*",
-                           [
-                             "configs",
-                             "public_configs",
-                             "suppressed_configs",
-                             "deps",
-                             "visibility",
-                           ])
-    testonly = true
-
-    if (defined(invoker.deps)) {
-      deps = invoker.deps
-    } else {
-      deps = []
-    }
-
-    # Adds a metadata key "rtc_cc_test" with a value of this test. This is used
-    # to confirm this test is included in a test suite.
-    metadata = {
-      rtc_cc_test = [
-        {
-          label = get_label_info(":$_lib_target_name", "label_no_toolchain")
-          type = "rtc_cc_test"
-        },
-      ]
-    }
-  }
-
-  _path_from_webrtc_root = rebase_path(".", webrtc_root)
-  if (_path_from_webrtc_root == ".") {
-    _binary_name = "${target_name}_bin"
-  } else {
-    _binary_name = string_replace(_path_from_webrtc_root, "/", "_") + "_" +
-                   target_name + "_bin"
-  }
-  rtc_test("${target_name}_bin") {
-    testonly = true
-
-    # Output into the target's directory.
-    output_name = _binary_name
-    deps = [ ":${_lib_target_name}" ]
-    if (defined(invoker.data_deps)) {
-      data_deps = invoker.data_deps
-    }
-  }
-}
-
-# Defines a test suite that aggregates multiple unit tests.
-#
-# This template is used to create "mega-targets" for CI/CQ. It collects
-# dependencies (which should be rtc_cc_test targets) and verifies that
-# they are reachable. The `tests_in_suites.json` file is generated by
-# walking the dependency graph starting from these suites.
-#
-# Arguments:
-#   tests: List of rtc_cc_test targets to include in this suite.
-#   deps: Additional dependencies (e.g. groups of tests).
-template("rtc_test_suite") {
-  _suite_name = target_name
-
-  # This checks that all of the tests strings listed are an rtc_cc_test by
-  # extracting their "rtc_cc_test" metadata into a file. This uses a simple
-  # set comparison in //tools_webrtc/verify_test_suite_metadata.py.
-  assert(defined(invoker.tests))
-
-  _metadata_map = []
-  _metadata_check_deps = []
-  foreach(t, invoker.tests) {
-    _test_label = get_label_info(t, "label_no_toolchain")
-    _safe_label = string_replace(_test_label, "//", "")
-    _safe_label = string_replace(_safe_label, "/", "_")
-    _safe_label = string_replace(_safe_label, ":", "_")
-    _output_file = "$target_gen_dir/${_suite_name}_${_safe_label}_metadata.json"
-    _check_target = "${_suite_name}_${_safe_label}_check"
-
-    generated_file(_check_target) {
-      testonly = true
-      outputs = [ _output_file ]
-      data_keys = [ "rtc_cc_test" ]
-      output_conversion = "json"
-      deps = [ t ]
-    }
-    _metadata_check_deps += [ ":${_check_target}" ]
-    _metadata_map += [
-      {
-        label = _test_label
-        output = rebase_path(_output_file, root_build_dir)
-      },
-    ]
-  }
-
-  write_file("$target_gen_dir/${_suite_name}_metadata_map.json",
-             _metadata_map,
-             "json")
-
-  action("${_suite_name}_verify_metadata") {
-    testonly = true
-    script = "//tools_webrtc/verify_test_suite_metadata.py"
-    inputs = [ "$target_gen_dir/${_suite_name}_metadata_map.json" ]
-    outputs = [ "$target_gen_dir/${_suite_name}_metadata.stamp" ]
-    args = [
-      rebase_path(inputs[0], root_build_dir),
-      rebase_path(outputs[0], root_build_dir),
-    ]
-    deps = _metadata_check_deps
-  }
-
-  rtc_test(_suite_name) {
-    forward_variables_from(invoker, "*", [ "tests" ])
-
-    if (!defined(deps)) {
-      deps = []
-    }
-    if (defined(invoker.deps)) {
-      deps += invoker.deps
-    }
-    deps += invoker.tests
-    deps += [ ":${_suite_name}_verify_metadata" ]
-  }
-}
