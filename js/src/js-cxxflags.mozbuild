






CXXFLAGS += CONFIG["MOZ_ICU_CFLAGS"]

if CONFIG["CC_TYPE"] in ("clang", "gcc"):
    
    COMPILE_FLAGS["WARNINGS_CXXFLAGS"] += ["-Werror=format"]




if CONFIG["CC_TYPE"] == "gcc":
    CXXFLAGS += ["-Wno-attributes"]






if CONFIG["CC_TYPE"] in ("clang", "clang-cl"):
    COMPILE_FLAGS["WARNINGS_CXXFLAGS"] += ["-Wdeprecated-this-capture"]
    COMPILE_FLAGS["WARNINGS_CXXFLAGS"] += ["-Wdeprecated-anon-enum-enum-conversion"]
    COMPILE_FLAGS["WARNINGS_CXXFLAGS"] += ["-Wdeprecated-enum-enum-conversion"]
