From: Mike Hommey <mh+mozilla@glandium.org>
Subject: Build fixes for iOS

--- a/gfx/cairo/cairo/src/cairo-quartz-font.c
+++ b/gfx/cairo/cairo/src/cairo-quartz-font.c
@@ -65,7 +65,9 @@
 
 /* These are private functions */
